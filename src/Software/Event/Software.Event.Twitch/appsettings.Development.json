{
  "Logging": {
    "LogLevel": {
      "Default": "Trace"
    }
  },
  "Hangfire": {
    "Redis": {
      "Host": "valkey",
      "Port": 6379,
      "UserSsl": false,
      "Prefix": "development:hangfire:event:twitch:"
    },
    "Dashboard": {
      "MaxSucceededListLength": 1000,
      "MaxDeletedListLength": 1000,
      "MaxStateHistoryLength": 10
    },
    "ExpirationTimeout": "01:00:00"
  }
}
