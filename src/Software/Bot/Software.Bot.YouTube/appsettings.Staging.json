{
  "Hangfire": {
    "Redis": {
      "UseSsl": true,
      "Prefix": "staging:hangfire:bot:youtube:"
    },
    "Dashboard": {
      "PrefixPath": "/api/bot/youtube",
      "MaxSucceededListLength": 1000000,
