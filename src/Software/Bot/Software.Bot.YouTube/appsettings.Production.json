{
  "Hangfire": {
    "Redis": {
      "UseSsl": true,
      "Prefix": "production:hangfire:bot:youtube:"
    },
    "Dashboard": {
      "PrefixPath": "/api/bot/youtube",
      "MaxSucceededListLength": 1000000,
      "MaxDeletedListLength": 1000000,
      "MaxStateHistoryLength": 100
    },
    "WorkerCount": 50,
    "ExpirationTimeout": "168:00:00"
  }
}
